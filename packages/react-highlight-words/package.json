{
  "name": "@cp949/react-highlight-words",
  "version": "0.1.0",
  "description": "React component and headless utilities for highlighting query matches inside text.",
  "license": "MIT",
  "author": "cp949",
  "homepage": "https://github.com/cp949/react-highlight-words#readme",
  "bugs": {
    "url": "https://github.com/cp949/react-highlight-words/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cp949/react-highlight-words.git",
    "directory": "packages/react-highlight-words"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist .turbo",
    "pack:dry-run": "pnpm build && pnpm pack --dry-run",
    "release:check": "pnpm test:run && pnpm check-types && pnpm build && pnpm pack --dry-run",
    "publish:npm": "pnpm release:check && pnpm publish --access public --no-git-checks"
  },
  "keywords": [
    "react",
    "react-component",
    "highlighter",
    "highlight",
    "text",
    "words",
    "matches",
    "search",
    "typescript"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jsdom": "^29.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
